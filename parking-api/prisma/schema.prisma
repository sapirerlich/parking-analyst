generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model chats {
  jid               String    @id @db.VarChar(255)
  name              String?   @db.Text
  last_message_time DateTime? @db.DateTime(0)
}

model messages {
  id         String    @db.VarChar(255)
  chat_jid   String    @db.VarChar(255)
  sender     String?   @db.Text
  content    String?   @db.Text
  timestamp  DateTime? @db.DateTime(0)
  is_from_me Boolean?

  @@id([id, chat_jid])
  @@index([chat_jid], map: "chat_jid")
}
